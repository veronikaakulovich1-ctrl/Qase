<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Regression" parallel="false" verbose="1">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.AnnotationTransformer"/>
    </listeners>

    <test name="1. Project Setup">
        <classes>
            <class name="tests.api.ProjectAPITest">
                <methods>
                    <include name="checkCreateProject"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="2. Repository - Suite">
        <classes>
            <class name="tests.api.SuiteAPITest"/>
        </classes>
    </test>

    <test name="3. Repository - Case">
        <classes>
            <class name="tests.api.CaseAPITest"/>
        </classes>
    </test>

    <test name="4. Plan">
        <classes>
            <class name="tests.api.PlanAPITest"/>
        </classes>
    </test>

    <test name="5. Run">
        <classes>
            <class name="tests.api.RunAPITest"/>
        </classes>
    </test>

    <test name="6. Result">
        <classes>
            <class name="tests.api.ResultAPITest"/>
        </classes>
    </test>

    <test name="7. Project Teardown">
        <classes>
            <class name="tests.api.ProjectAPITest">
                <methods>
                    <include name="checkDeleteProject"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
